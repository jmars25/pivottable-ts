{
  "name": "pivottable-ts",
  "version": "1.0.0",
  "description": "TypeScript pivot table with drag-and-drop, vanilla adapter, Chart.js renderers and 15-language locale support",
  "main": "dist/pivot.js",
  "module": "dist/pivot.mjs",
  "types": "dist/pivot.d.ts",
  "exports": {
    ".": {
      "types": "./dist/pivot.d.ts",
      "import": "./dist/pivot.mjs",
      "require": "./dist/pivot.js"
    },
    "./vanilla": {
      "types":   "./dist/adapters/vanilla.d.ts",
      "import":  "./dist/adapters/vanilla.mjs",
      "require": "./dist/adapters/vanilla.js"
    },
    "./renderers/chartjs": {
      "types":   "./dist/renderers/chartjs.d.ts",
      "import":  "./dist/renderers/chartjs.mjs",
      "require": "./dist/renderers/chartjs.js"
    },
    "./locales": {
      "types":   "./dist/locales/index.d.ts",
      "import":  "./dist/locales/index.mjs",
      "require": "./dist/locales/index.js"
    },
    "./dist/pivot.css":   "./dist/pivot.css",
    "./dist/pivot.min.js": "./dist/pivot.min.js"
  },
  "files": [
    "dist"
  ],
  "style": "dist/pivot.css",
  "unpkg": "dist/pivot.min.js",
  "jsdelivr": "dist/pivot.min.js",
  "scripts": {
    "build": "tsup && node -e \"require('fs').copyFileSync('src/pivot.css','dist/pivot.css')\"",
    "prepare": "npm run build",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "pivot",
    "crosstab",
    "grid",
    "table",
    "pivottable",
    "pivotgrid",
    "pivotchart",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/jmars25/pivottable.git"
  },
  "author": "jmars25",
  "contributors": [
    "Nicolas Kruchten (original pivottable author, https://github.com/nicolaskruchten/pivottable)"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/jmars25/pivottable/issues"
  },
  "homepage": "https://github.com/jmars25/pivottable",
  "dependencies": {
    "sortablejs": "^1.15.7"
  },
  "peerDependencies": {
    "chart.js": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "chart.js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/sortablejs": "^1.15.9",
    "chart.js": "^4.5.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
