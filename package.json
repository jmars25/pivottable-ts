{
  "name": "pivottable",
  "version": "2.23.0",
  "description": "Javascript Pivot Table (aka Pivot Grid, Pivot Chart, Cross-Tab) implementation with drag'n'drop",
  "main": "dist/pivot.js",
  "module": "dist/pivot.mjs",
  "types": "dist/pivot.d.ts",
  "exports": {
    ".": {
      "types": "./dist/pivot.d.ts",
      "import": "./dist/pivot.mjs",
      "require": "./dist/pivot.js"
    },
    "./jquery": {
      "import": "./dist/adapters/jquery.mjs",
      "require": "./dist/adapters/jquery.js"
    },
    "./vanilla": {
      "import": "./dist/adapters/vanilla.mjs",
      "require": "./dist/adapters/vanilla.js"
    },
    "./renderers/chartjs": {
      "types":   "./dist/renderers/chartjs.d.ts",
      "import":  "./dist/renderers/chartjs.mjs",
      "require": "./dist/renderers/chartjs.js"
    },
    "./locales": {
      "types":   "./dist/locales/index.d.ts",
      "import":  "./dist/locales/index.mjs",
      "require": "./dist/locales/index.js"
    }
  },
  "files": [
    "dist",
    "src/pivot.css"
  ],
  "style": "dist/pivot.css",
  "scripts": {
    "build": "tsup && node -e \"require('fs').copyFileSync('src/pivot.css','dist/pivot.css')\"",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "pivot",
    "crosstab",
    "grid",
    "table",
    "pivottable",
    "pivotgrid",
    "pivotchart"
  ],
  "repository": {
    "type": "git",
    "url": "git://github.com/jmars25/pivottable.git"
  },
  "author": "Nicolas Kruchten",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/jmars25/pivottable/issues"
  },
  "homepage": "https://github.com/jmars25/pivottable",
  "peerDependencies": {
    "chart.js": ">=4.0.0",
    "jquery": ">=1.9.0",
    "sortablejs": ">=1.15.0"
  },
  "peerDependenciesMeta": {
    "chart.js": {
      "optional": true
    },
    "jquery": {
      "optional": true
    },
    "sortablejs": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/sortablejs": "^1.15.9",
    "chart.js": "^4.5.1",
    "sortablejs": "^1.15.7",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
